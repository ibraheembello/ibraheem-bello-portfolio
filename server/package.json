    "@types/morgan": "^1.9.9",
    "@types/nodemailer": "^6.4.14",
    "@types/node": "^20.11.5",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
