{
  "name": "portfolio-server",
  "version": "1.0.0",
  "description": "Express.js backend for Ibraheem Bello's portfolio",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
